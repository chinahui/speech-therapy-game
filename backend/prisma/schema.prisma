generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  childName String?
  childAge  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assessments Assessment[]
  progress    Progress[]
}

model Assessment {
  id            String   @id @default(cuid())
  userId        String
  comprehension Int
  expression    Int
  pronunciation Int
  social        Int
  totalScore    Int
  ageLevel      String?
  details       String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  gameType  String
  score     Int
  stars     Int
  duration  Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
